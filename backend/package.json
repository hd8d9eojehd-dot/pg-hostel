    "@types/node": "^20.14.0",
    "@types/node-cron": "^3.0.11",
    "@types/qrcode": "1.5.6",
    "nodemon": "^3.1.0",
    "prisma": "^5.14.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0"
